POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=asphanyx
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:change_me@postgres:5432/asphanyx

REDIS_PASSWORD=change_me
REDIS_PORT=6379
REDIS_URL=redis://:change_me@redis:6379

PORT=8081

RUST_LOG=info

# JWT Configuration
JWT_SECRET=replace_with_64_plus_char_random_secret_for_prod
SWAGGER_ENABLED=false

# Session and Registration Settings
SESSION_DURATION_SECONDS=900
PENDING_REGISTRATION_TTL_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=900
REFRESH_TOKEN_DURATION_SECONDS=604800

# SMTP Configuration
SMTP_HOST=smtp.test.local
SMTP_PORT=465
SMTP_USERNAME=test_user
SMTP_PASSWORD=test_password
SMTP_FROM=no-reply@example.test

# Google OAuth (Fixed redirect URI for all tenants)
GOOGLE_REDIRECT_URI=http://localhost:8081/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000
ADMIN_PANEL_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TRUSTED_PROXY_IPS=127.0.0.1,::1

# Account lockout configuration
LOCKOUT_THRESHOLD=3
LOCKOUT_DURATION_SECONDS=900

# SMTP / Email TEST (Used by 'cargo test')
TEST_SMTP_HOST=smtp.test.local
TEST_SMTP_PORT=465
TEST_SMTP_USERNAME=test_user
TEST_SMTP_PASSWORD=test_password
TEST_SMTP_FROM=no-reply@example.test
TEST_SMTP_TO=qa@example.test
