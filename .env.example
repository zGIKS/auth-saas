# Servidor
PORT=8081
RUST_LOG=info

# Base de Datos (SQLite)
DATABASE_URL=sqlite://data/main.db?mode=rwc
SQLITE_DATA_DIR=data/tenants

# Redis
REDIS_URL=redis://localhost:6379

# JWT y Seguridad
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
SWAGGER_ENABLED=true

# Tiempos de Vida (Segundos)
SESSION_DURATION_SECONDS=900
PENDING_REGISTRATION_TTL_SECONDS=900
PASSWORD_RESET_TTL_SECONDS=900
REFRESH_TOKEN_DURATION_SECONDS=604800

# Bloqueo de Cuenta
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_SECONDS=900

# URLs
FRONTEND_URL=http://localhost:3000
GOOGLE_REDIRECT_URI=http://localhost:8081/api/v1/auth/google/callback

# SMTP
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=user
SMTP_PASSWORD=pass
SMTP_FROM=no-reply@yourdomain.com
